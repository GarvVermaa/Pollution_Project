# ── Backend (Backend/.env) ─────────────────────────────────────────

# Port the Node.js Express server listens on inside its container
PORT=5000

# "production" disables verbose error stack traces in responses
NODE_ENV=production

ML_SERVICE_URL=http://ml_service:5001


FRONTEND_URL=http://localhost

# CPCB Air Quality API key from data.gov.in
# Get one at: https://data.gov.in/resource/real-time-air-quality-index-various-locations
# NEVER put the real key in this file — only in Backend/.env
CPCB_API_KEY=your_cpcb_api_key_here
